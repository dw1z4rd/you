# LLM provider (Ollama)
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# Admin panel
ADMIN_TOKEN=change-me

# PartyKit host (leave as-is for local dev; set to your deployed URL in prod)
# Used server-side by the admin page to query the registry
PARTYKIT_HOST=localhost:1999

# PartyKit host exposed to the browser (must be PUBLIC_ prefix for SvelteKit)
# Same value as PARTYKIT_HOST for local dev
PUBLIC_PARTYKIT_HOST=localhost:1999
